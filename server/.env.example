# JN Enterprise - Industrial Environment Configuration
# Duplicate this file to .env and configure for local/production nodes.

# System Port
PORT=5000

# Registry Database Node (Industrial PostgreSQL)
DATABASE_URL="postgresql://jn_admin:secure_protocol@localhost:5432/jn_enterprise?schema=public"

# Identity Security Layer
JWT_SECRET="INDUSTRIAL_GRADE_SHIELD_KEY_9902"
JWT_EXPIRES_IN="7d"

# Asset Storage (Matrix Images)
STORAGE_PROVIDER="local" # options: local, s3, cloudinary
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# Logistics Notification Protocol
SMTP_HOST="smtp.jn-logistics.com"
SMTP_PORT=587
SMTP_USER="procurement-node@jn-enterprise.com"
SMTP_PASS="secure_smtp_pass"

# Production Hardening
NODE_ENV="production"
CORS_ORIGIN="http://localhost:5173"
